#!/usr/bin/env bash
set -euo pipefail

# rnsbt — recursive next-sbt
# Runs sbt with the sloth Java agent injected into the sbt JVM
# AND all forked child JVMs (via JAVA_TOOL_OPTIONS).
# Note: JAVA_TOOL_OPTIONS causes "Picked up JAVA_TOOL_OPTIONS: ..." on stderr
# for every JVM launch — this is harmless.

SLOTH_AGENT="${SLOTH_AGENT:-$HOME/.sloth/agent.jar}"

if [[ ! -f "$SLOTH_AGENT" ]]; then
  echo "rnsbt: agent jar not found: $SLOTH_AGENT" >&2
  echo "  Install it with: sbt agentInstall" >&2
  echo "  Or set SLOTH_AGENT to the correct path" >&2
  exit 1
fi

export JAVA_TOOL_OPTIONS="-javaagent:$SLOTH_AGENT"

exec sbt "-J-javaagent:$SLOTH_AGENT" "$@"
